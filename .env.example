# PostgreSQL local (Docker Compose)
POSTGRES_DB=dashboard
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dashboard

# Prisma — pointe vers le Postgres local
DATABASE_URL="postgresql://dashboard:dashboard@localhost:5433/dashboard?schema=public"

# --- Sync Crédit Mutuel (optionnel) ---
# Lus par le sidecar Python (woob). Laisser vide pour désactiver la sync.
# La 1re sync déclenche une validation sur ton app Confirmation Mobile.
CM_LOGIN=
CM_PASSWORD=
# `par` (particuliers) ou `pro` (espace pro)
CM_WEBSITE=par

# URL du sidecar woob — défaut OK avec le docker-compose.yml fourni
SIDECAR_URL=http://127.0.0.1:8765
